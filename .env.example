# =============================================================================
# Strype Cloud Platform — Environment Variables
# =============================================================================
# Copy to .env and fill in your values before deploying.
# All variables without defaults are REQUIRED in production.

# --- Core ---
# Environment: "dev" for local development, "production" for deployment
ENV=dev

# Secret key for JWT signing. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# REQUIRED in production (app will refuse to start with the default value)
SECRET_KEY=dev-secret-key-change-in-production

# Path to SQLite database file (relative to working directory or absolute)
DATABASE_PATH=backend/data/strype.db

# JWT access token expiration in minutes (default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# JWT refresh token expiration in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
# Comma-separated allowed origins. MUST be specific in production (not "*")
# Example: https://strype.io,https://www.strype.io
CORS_ORIGINS=*

# Frontend URL for email links (password reset, verification)
FRONTEND_URL=http://localhost:8000

# --- Admin ---
# Email address of the admin user (gets admin privileges on login)
ADMIN_EMAIL=admin@strype.io

# --- Stripe Billing ---
# Stripe secret key (sk_test_... or sk_live_...)
STRIPE_SECRET_KEY=

# Stripe Price ID for Pro plan subscription (price_...)
STRIPE_PRICE_ID=

# Stripe Price ID for Robot plan subscription (price_...)
STRIPE_ROBOT_PRICE_ID=

# Stripe webhook endpoint signing secret (whsec_...)
# REQUIRED when STRIPE_SECRET_KEY is set
STRIPE_WEBHOOK_SECRET=

# Robot deposit amount in dollars (0 = no deposit required)
ROBOT_DEPOSIT=0

# --- Email (SendGrid) ---
# SendGrid API key for transactional email (verification, password reset)
SENDGRID_API_KEY=

# Sender email address (must be verified in SendGrid)
FROM_EMAIL=noreply@strype.io

# --- Shipping (EasyPost) ---
# EasyPost API key for robot shipment tracking
EASYPOST_API_KEY=

# Ship-from address for robot fulfillment
SHIP_FROM_STREET=
SHIP_FROM_CITY=
SHIP_FROM_STATE=
SHIP_FROM_ZIP=
